@page "/payment-terms"
@using InvoicingSystem.Server.Data.Models
@using Radzen
@using Radzen.Blazor
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Listado de Términos de Pago</PageTitle>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .page-header h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #1f2937;
    }

    .rz-pagesize-text {
        display: none;
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }
        to {
            transform: translateX(0);
        }
    }
</style>

<div class="page-header">
    <h1>Gestión de Términos de Pago</h1>
    <RadzenButton Text="Añadir Términos de Pago"
                  Icon="add_circle_outline"
                  ButtonStyle="ButtonStyle.Primary"
                  Click="@GoToAdd"
                  Size="ButtonSize.Large" />
</div>

<div class="row">
    <div class="col-md-12">
        <RadzenDataGrid @ref="grid" Data="@paymentTerms" Count="@count" TItem="PaymentTerms" LoadData="@LoadData"
                        AllowFiltering="true" AllowPaging="true" AllowSorting="true"
                        PageSize="10"
                        PageSizeOptions="@(new int[] { 5, 10, 20, 50 })"
                        ShowPagingSummary="true"
                        PagingSummaryFormat="Mostrando {0}-{1} de {2} términos de pago"
                        IsLoading="@isLoading"
                        RowDoubleClick="@OnRowDoubleClick"
                        Style="max-height:397.6px">
            <Columns>
                <RadzenDataGridColumn TItem="PaymentTerms" Property="Description" Title="Descripción" Width="300px">
                    <Template Context="term">
                        @if (string.IsNullOrEmpty(term.Description))
                        {
                            <div class="placeholder-glow">
                                <span class="placeholder col-12"></span>
                            </div>
                        }
                        else
                        {
                            @term.Description
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="PaymentTerms" Property="PaymentDays" Title="Días" Width="120px">
                    <Template Context="term">
                        @if (term.PaymentDays < 0)
                        {
                            <div class="placeholder-glow">
                                <span class="placeholder col-6"></span>
                            </div>
                        }
                        else
                        {
                            <text>@term.PaymentDays días</text>
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="PaymentTerms" Filterable="false" Sortable="false" TextAlign="TextAlign.Center" Width="80px">
                    <Template Context="term">
                        <RadzenButton Icon="delete"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Variant="Variant.Flat"
                                      Size="ButtonSize.Medium"
                                      Disabled="@(term.PaymentTermsId == Guid.Empty)"
                                      Click="@(() => DeletePaymentTerm(term.PaymentTermsId))"
                                      @onclick:stopPropagation="true" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
</div>

@if (sidebarExpanded)
{
    <div class="sidebar-overlay" @onclick="@(() => CloseSidebar(false))"></div>

    <div class="sidebar-panel sidebar-right">
        <div class="sidebar-header">
            <h2 class="sidebar-title-large">@sidebarTitle</h2>
            <RadzenButton Icon="close"
                          ButtonStyle="ButtonStyle.Light"
                          Variant="Variant.Flat"
                          Size="ButtonSize.Small"
                          Click="@(() => CloseSidebar(false))" />
        </div>

        <div class="sidebar-content">
            <PaymentTermEdit IsNew="@isNewPaymentTerm"
                            PaymentTermsId="@selectedPaymentTermId"
                            OnClose="@CloseSidebar" />
        </div>
    </div>
}


    <style>
        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.5);
            z-index: 9998;
        }

        .sidebar-panel {
            position: fixed;
            top: 0;
            height: 100vh;
            background: white;
            z-index: 9999;
            box-shadow: -2px 0 10px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }

        .sidebar-right {
            right: 0;
            width: 600px;
            animation: slideInRight 0.3s ease-out;
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .sidebar-title-large {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 600;
            color: #1f2937;
        }

        .sidebar-content {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem;
        }
    </style>