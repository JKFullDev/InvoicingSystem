@using InvoicingSystem.Server.Data.Models
@using InvoicingSystem.Client.Interfaces
@using Radzen
@using Radzen.Blazor

<RadzenStack Gap="1rem">
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12">
            <RadzenFormField Text="Producto" Variant="Variant.Outlined" class="form-field-full">
                <RadzenDropDown @bind-Value="line.ProductId"
                                @bind-Value:after="OnProductChangedAsync"
                                Data="@Products"
                                TextProperty="Name"
                                ValueProperty="ProductId"
                                Variant="Variant.Outlined"
                                class="input-full" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12">
            <RadzenFormField Text="Descripción Personalizada" Variant="Variant.Outlined" class="form-field-full">
                <RadzenTextArea @bind-Value="line.CustomDescription"
                                Rows="3"
                                MaxLength="500"
                                class="input-full" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1rem">
        <RadzenColumn Size="4">
            <RadzenFormField Text="Precio Unitario (€)" Variant="Variant.Outlined" class="form-field-full">
                <RadzenNumeric @bind-Value="line.UnitPrice"
                               ShowUpDown="false"
                               Min="0"
                               Max="999999.99m"
                               Format="c2"
                               Disabled="true"
                               class="input-full" />
            </RadzenFormField>
            <small class="help-text">Precio del producto (no editable)</small>
        </RadzenColumn>
        <RadzenColumn Size="4">
            <RadzenFormField Text="Cantidad" Variant="Variant.Outlined" class="form-field-full">
                <RadzenNumeric @bind-Value="line.Quantity"
                               ShowUpDown="true"
                               Min="1"
                               Max="10000"
                               class="input-full" />
            </RadzenFormField>
        </RadzenColumn>
        <RadzenColumn Size="4">
            <RadzenFormField Text="Tipo de IVA" Variant="Variant.Outlined" class="form-field-full">
                <RadzenDropDown @bind-Value="line.TaxRateId"
                                Data="@TaxRates"
                                TextProperty="Name"
                                ValueProperty="TaxRateId"
                                Variant="Variant.Outlined"
                                class="input-full" />
            </RadzenFormField>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12">
            <div class="line-total-box">
                <strong class="line-total-text">Total línea: @line.TotalLine.ToString("C2")</strong>
            </div>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1rem" class="row-spacing">
        <RadzenColumn Size="12" class="text-right">
            <RadzenButton Text="Cancelar"
                          ButtonStyle="ButtonStyle.Light"
                          Click="@Cancel"
                          class="btn-cancel" />
            <RadzenButton Text="Guardar"
                          ButtonStyle="ButtonStyle.Success"
                          Icon="save"
                          Click="@Save" />
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

<style>
    /* Inputs y FormFields */
    .form-field-full {
        width: 100%;
    }

    .input-full {
        width: 100%;
    }

    /* Texto de ayuda */
    .help-text {
        color: #6b7280;
        display: block;
        margin-top: 0.25rem;
    }

    /* Total de línea */
    .line-total-box {
        background-color: #f9fafb;
        padding: 1rem;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
    }

    .line-total-text {
        color: #1f2937;
    }

    /* Espaciado y alineación */
    .row-spacing {
        margin-top: 1rem;
    }

    .text-right {
        text-align: right;
    }

    .btn-cancel {
        margin-right: 0.5rem;
    }
</style>
