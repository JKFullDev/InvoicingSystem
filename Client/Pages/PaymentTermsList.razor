@page "/payment-terms"
@using InvoicingSystem.Server.Data.Models
@using Radzen
@using Radzen.Blazor
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Listado de Términos de Pago</PageTitle>

<style>
    /* Overlay de fondo semi-transparente */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.3s ease-in-out;
    }

    /* Contenedor del formulario modal */
    .modal-content {
        background: white;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        max-width: 600px;
        width: 90%;
        max-height: 85vh;
        overflow-y: auto;
        animation: slideDown 0.3s ease-in-out;
    }

    /* Animación de aparición del overlay */
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    /* Animación de deslizamiento del modal */
    @@keyframes slideDown {
        from {
            transform: translateY(-50px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    /* Espaciado interno del modal */
    .modal-body {
        padding: 2.5rem;
    }

    /* Estilo para el header del modal */
    .modal-header {
        padding: 1.5rem 2rem;
        border-bottom: 1px solid #e0e0e0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 12px 12px 0 0;
    }

    .modal-header h3 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 600;
        color: white;
    }

    /* Botón de cerrar (X) */
    .modal-close {
        background: rgba(255, 255, 255, 0.2);
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: white;
        padding: 0;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: all 0.2s;
    }

    .modal-close:hover {
        background-color: rgba(255, 255, 255, 0.3);
        transform: scale(1.1);
    }

    /* Contenedor centrado para los campos del formulario */
    .form-field-container {
        max-width: 500px;
        margin: 0 auto;
    }

    /* Estilo para los labels */
    .form-field-container .rz-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 0.5rem;
        display: block;
    }

    /* Espaciado entre campos */
    .form-field {
        margin-bottom: 1.5rem;
    }

    /* Estilo para los inputs */
    .form-field-container .rz-textbox,
    .form-field-container .rz-numeric {
        width: 100% !important;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        transition: border-color 0.2s;
    }

    .form-field-container .rz-textbox:focus,
    .form-field-container .rz-numeric:focus {
        border-color: #667eea;
        outline: none;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    /* Estilo para el texto de ayuda */
    .help-text {
        font-size: 0.875rem;
        color: #6b7280;
        margin-top: 0.25rem;
        display: block;
    }

    /* Separador visual */
    .form-divider {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 2rem 0;
    }

    /* Header de la página */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .page-header h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #1f2937;
    }

    /* Validación de error */
    .rz-message {
        margin-top: 0.25rem;
    }
</style>

<div class="page-header">
    <h1>Directorio de Términos de Pago</h1>
    <RadzenButton Text="Añadir Términos de Pago" 
                  Icon="add_circle_outline" 
                  ButtonStyle="ButtonStyle.Primary" 
                  Click="@GoToAdd" 
                  Disabled="@showForm" 
                  Size="ButtonSize.Large" />
</div>

@* FORMULARIO DESPLEGABLE (Añadir/Editar) - MODAL OVERLAY *@
@if (showForm && paymentTermsToEdit != null)
{
    <div class="modal-overlay" @onclick="@CancelEdit">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(isNew ? "Nuevo Término de Pago" : "Editar Término de Pago")</h3>
                <button class="modal-close" @onclick="@CancelEdit" aria-label="Cerrar">
                    ✕
                </button>
            </div>
            <div class="modal-body">
                <RadzenTemplateForm Data="@paymentTermsToEdit" Submit="@SavePaymentTerms" TItem="PaymentTerms">
                    <div class="form-field-container">
                        <!-- no se pone porque es guid
                        @* Campo ID - Solo lectura *@
                        <div class="form-field">
                            <RadzenLabel Text="ID" />
                            <RadzenTextBox Value="@paymentTermsToEdit.PaymentTermsId.ToString()" 
                                          Disabled="true" />
                            <small class="help-text">Generado automáticamente</small>
                        </div>
                        -->
                        @* Campo Descripción *@
                        <div class="form-field">
                            <RadzenLabel Text="Descripción *" />
                            <RadzenTextBox @bind-Value="paymentTermsToEdit.Description" 
                                          Name="Description" 
                                          Placeholder="Ej: 30 días, Pago inmediato, Net 15..." 
                                          MaxLength="100" />
                            <RadzenRequiredValidator Component="Description" 
                                                    Text="La descripción es obligatoria" 
                                                    Style="display: block" />
                        </div>

                        @* Campo Días de pago *@
                        <div class="form-field">
                            <RadzenLabel Text="Días de pago *" />
                            <RadzenNumeric @bind-Value="paymentTermsToEdit.PaymentDays" 
                                          Name="PaymentDays" 
                                          ShowUpDown="false" 
                                          Min="0" 
                                          Max="365" 
                                          Placeholder="Número de días" />
                            <small class="help-text">Entre 0 y 365 días</small>
                            <RadzenRequiredValidator Component="PaymentDays" 
                                                    Text="Los días de pago son obligatorios" 
                                                    Style="display: block" />
                        </div>

                        <hr class="form-divider" />

                        @* Botones de acción *@
                        <div class="d-flex justify-content-end gap-2">
                            <RadzenButton Text="Cancelar" 
                                        ButtonStyle="ButtonStyle.Light" 
                                        Click="@CancelEdit" 
                                        Size="ButtonSize.Medium" 
                                        Style="min-width: 100px;" />
                            <RadzenButton Text="Guardar" 
                                        ButtonType="ButtonType.Submit" 
                                        ButtonStyle="ButtonStyle.Primary" 
                                        Icon="save" 
                                        Size="ButtonSize.Medium" 
                                        Style="min-width: 100px;" />
                        </div>
                    </div>
                </RadzenTemplateForm>
            </div>
        </div>
    </div>
}

@* TABLA PRINCIPAL *@
<div class="row">
    <div class="col-md-12">
        <RadzenDataGrid @ref="grid" Data="@paymentTerms" Count="@count" TItem="PaymentTerms" LoadData="@LoadData"
                        AllowFiltering="true" AllowPaging="true" AllowSorting="true" PageSize="10"
                        IsLoading="@isLoading" RowDoubleClick="@OnRowDoubleClick">
            <Columns>
                <RadzenDataGridColumn TItem="PaymentTerms" Property="Description" Title="Descripcion" Width="40%" />
                <RadzenDataGridColumn TItem="PaymentTerms" Property="PaymentDays" Title="Días de pago" Width="40%" />

                @* Columna solo para el botón de borrar *@
                <RadzenDataGridColumn TItem="PaymentTerms" Context="paymentTerms" Filterable="false" Sortable="false" TextAlign="TextAlign.Center" Width="10%">
                    <Template Context="paymentTerms">
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Size="ButtonSize.Medium" Click="@(() => DeletePaymentTerms(paymentTerms.PaymentTermsId))" @onclick:stopPropagation="true" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
</div>