@page "/customers"
@using InvoicingSystem.Client.Components;
@using InvoicingSystem.Server.Data.Models
@using Radzen
@using Radzen.Blazor
@using System.Linq
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Listado de Clientes</PageTitle>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .page-header h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #1f2937;
    }

    .rz-pagesize-text {
        display: none;
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }
        to {
            transform: translateX(0);
        }
    }
</style>

<div class="page-header">
    <h1>Gestión de Clientes</h1>
    <RadzenButton Text="Añadir Cliente"
                  Icon="add_circle_outline"
                  ButtonStyle="ButtonStyle.Primary"
                  Click="@GoToAdd"
                  Size="ButtonSize.Large" />
</div>

<div class="row">
    <div class="col-md-12">
        <RadzenDataGrid @ref="grid" Data="@customers" Count="@count" TItem="Customers" LoadData="@LoadData"
                        AllowFiltering="true" AllowPaging="true" AllowSorting="true"
                        PageSize="10"
                        PageSizeOptions="@(new int[] { 5, 10, 20, 50 })"
                        ShowPagingSummary="true"
                        PagingSummaryFormat="Mostrando {0}-{1} de {2} clientes"
                        IsLoading="@isLoading"
                        RowDoubleClick="@OnRowDoubleClick"
                        RowExpand="@OnRowExpand"
                        Style="max-height:397.6px"
                        FilterMode="FilterMode.Advanced">

            <Template Context=currentCustomer>
                <CustomerDetailsChart CustomerId="@currentCustomer.CustomerId"
                                      Invoices="@(currentCustomer.SalesInvoiceHeaders?.ToList() ?? new List<SalesInvoiceHeaders>())" />
            </Template>
            <Columns>
                <RadzenDataGridColumn TItem="Customers" Property="CustomerId" Title="ID Cliente" Width="120px">
                    <Template Context="customer">
                        @if (string.IsNullOrEmpty(customer.CustomerId))
                        {
                            <div class="placeholder-glow">
                                <span class="placeholder col-12"></span>
                            </div>
                        }
                        else
                        {
                            @customer.CustomerId
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Customers" Property="Name" Title="Nombre" Width="200px">
                    <Template Context="customer">
                        @if (string.IsNullOrEmpty(customer.Name))
                        {
                            <div class="placeholder-glow">
                                <span class="placeholder col-12"></span>
                            </div>
                        }
                        else
                        {
                            @customer.Name
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Customers" Property="City" Title="Ciudad" Width="150px">
                    <Template Context="customer">
                        @if (string.IsNullOrEmpty(customer.City))
                        {
                            <div class="placeholder-glow">
                                <span class="placeholder col-12"></span>
                            </div>
                        }
                        else
                        {
                            @customer.City
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Customers" Property="Nif" Title="NIF" Width="120px">
                    <Template Context="customer">
                        @if (string.IsNullOrEmpty(customer.Nif))
                        {
                            <div class="placeholder-glow">
                                <span class="placeholder col-12"></span>
                            </div>
                        }
                        else
                        {
                            @customer.Nif
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Customers" Filterable="false" Sortable="false" TextAlign="TextAlign.Center" Width="80px">
                    <Template Context="customer">
                        <RadzenButton Icon="delete"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Variant="Variant.Flat"
                                      Size="ButtonSize.Medium"
                                      Disabled="@(string.IsNullOrEmpty(customer.CustomerId))"
                                      Click="@(() => DeleteCustomer(customer.CustomerId))"
                                      @onclick:stopPropagation="true" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
</div>

@* Sidebar deslizante desde la derecha para editar/crear clientes *@
@if (sidebarExpanded)
{
    <div class="sidebar-overlay" @onclick="@(() => CloseSidebar(false))"></div>

    <div class="sidebar-panel sidebar-right">
        <div class="sidebar-header">
            <h2 class="sidebar-title-large">@sidebarTitle</h2>
            <RadzenButton Icon="close"
            ButtonStyle="ButtonStyle.Light"
            Variant="Variant.Flat"
            Size="ButtonSize.Small"
            Click="@(() => CloseSidebar(false))" />
        </div>

        <div class="sidebar-content">
            <CustomerEdit IsNew="@isNewCustomer"
            CustomerId="@selectedCustomerId"
            OnClose="@CloseSidebar" />
        </div>
    </div>
}
<style>
        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.5);
            z-index: 9998;
        }

        .sidebar-panel {
            position: fixed;
            top: 0;
            height: 100vh;
            background: white;
            z-index: 9999;
            box-shadow: -2px 0 10px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }

        .sidebar-right {
            right: 0;
            width: 600px;
            animation: slideInRight 0.3s ease-out;
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .sidebar-title-large {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 600;
            color: #1f2937;
        }

        .sidebar-content {
            flex: 1;
            overflow-y: auto;
            padding: 1.5rem;
        }
    </style>

