@page "/catalogue"
@using InvoicingSystem.Server.Data.Models
@using InvoicingSystem.Client.Components
@using Radzen
@using Radzen.Blazor

@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))


<PageTitle>Catálogo de Productos</PageTitle>

<style>
    .cart-button-wrapper {
        position: relative;
        display: inline-block;
    }

    .cart-badge {
        position: absolute;
        top: -8px;
        right: -8px;
        background: #dc3545;
        color: white;
        border-radius: 50%;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: bold;
        z-index: 1000;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e5e7eb;
    }

    .page-header h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #1f2937;
    }

    .rz-pagesize-text {
        display: none;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .product-card {
        background: white !important;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    }

    .sidebar-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.5);
        z-index: 9998;
    }

    .sidebar-panel {
        position: fixed;
        top: 0;
        height: 100vh;
        background: white;
        z-index: 9999;
        box-shadow: -2px 0 10px rgba(0, 0, 0, 0.1);
        display: flex;
        flex-direction: column;
    }

    .sidebar-right {
        right: 0;
        width: 600px;
        animation: slideInRight 0.3s ease-out;
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
        }
        to {
            transform: translateX(0);
        }
    }

    .sidebar-header {
        padding: 1.5rem;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .sidebar-title-large {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 600;
        color: #1f2937;
    }

    .sidebar-content {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }
</style>

<div class="page-header">
    <h1>Catálogo de Productos</h1>
    <div class="cart-button-wrapper">
        <RadzenButton Icon="shopping_cart"
                      ButtonStyle="ButtonStyle.Primary"
                      Size="ButtonSize.Large"
                      Click="@ToggleCartSidebar" />
        @if (cartItemCount > 0)
        {
            <span class="cart-badge">@cartItemCount</span>
        }
    </div>
</div>

@if (isLoading)
{
    <RadzenProgressBar ProgressBarStyle="ProgressBarStyle.Primary" Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" AriaLabel="Primary loading" />
}
else if (products != null && products.Any())
{
    <div class="products-grid" >
        @foreach (var item in products)
        {
            <RadzenCard Variant="Variant.Flat" class="product-card animate__animated animate__fadeInUp">
                <RadzenStack Orientation="Orientation.Vertical" JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center" Gap="1rem" class="rz-p-4">
                    <RadzenImage Path="@GetProductImage(item)"
                                 Style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px;"
                                 AlternateText="@item.Name" />
                    <RadzenStack Gap="0" Style="width: 100%">
                        <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-2 rz-my-0">Producto</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1"><b>@item.Name</b></RadzenText>
                        <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Precio</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1"><b>@item.CurrentPrice.ToString("C2")</b></RadzenText>
                    </RadzenStack>
                    <RadzenButton Text="Añadir al carrito"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Style="width: 100%"
                                  Click="@(() => AddToCart(item))" />
                </RadzenStack>
            </RadzenCard>
        }
    </div>
}
else
{
    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter">
        No hay productos disponibles en el catálogo.
    </RadzenAlert>
}

<CartSidebar IsOpen="@isCartOpen" OnClose="@CloseCartSidebar" />



